  m_Script: {fileID: 11500000, guid: 94ffd712ae9ff5542987662196fc462b, type: 3}
  m_Name: Ocelated Eagle Ray
  m_EditorClassIdentifier: Assembly-CSharp::EndangeredFishDefinition
  fishName: Ocellated eagle ray
  scientificName: Aetobatus ocellatus
  description: 'Found in coastal waters including estuarine habitats. Can grow over
    3 m disc width and up to 880 cm total length if the long tail is undamaged. Feeds
    mainly on hard-shelled bottom-dwelling invertebrates such as hermit crabs, whelks,
    oysters, clams and large molluscs, crustraceans, worms, octopuses and fishes
    . Ovoviviparous. '
  status: 1
  iucnStatus: Endangered
  populationTrend: Decreasing
  habitat: Coral reefs, particularly outer reef slopes and drop-offs
  distribution: Indo-Pacific region including Philippines, from Red Sea to Pacific
    islands
  threats: Collection for aquarium trade, habitat destruction, overfishing, coral
    reef degradation
  importance: Important reef species, maintains reef ecosystem balance, valuable
    in aquarium trade, indicator of reef health
  conservationEfforts: Marine protected areas, sustainable collection practices,
    reef conservation, size and catch limits
