                "conditionValue": "COMPLETED"
              }
            ],
            "triggersOnShow": [
              "RecordTalkedToNPC:Ruben"
            ],
            "choices": [
              {
                "choiceText": "Cassandra sent me to learn processing.",
                "resultDialogId": "processing_tutorial_intro",
                "triggersOnShow": [],
                "showConditions": []
              },
              {
                "choiceText": "I want to process my fish.",
                "resultDialogId": "",
                "triggersOnChoose": ["RecordFishProcessed:1", "CompleteQuest:ART_OF_VALUE_4", "LoadScene:DeboningMainScene", "PlayMusic:DeboningBGM"],
                "showConditions": []
