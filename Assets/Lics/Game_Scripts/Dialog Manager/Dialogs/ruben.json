        {
          "key": "first_meeting_standard",
          "value": {
            "speakerName": "Ruben",
            "text": "Queue's to the left. Standard processing fee is 10% of market value.\n\nIf you're not here with fish, state your business. Time is freshness.",
            "showAsAction": true,
            "showConditions": [
              {
                "conditionType": 10,
                "conditionKey": "Ruben",
                "conditionValue": "false",
                "expectedBool": true
              },
              {
